# Keterangan: Sebagian besar konfigurasi (API Key, dll) dapat diatur langsung melalui dashboard aplikasi.
# File ini digunakan untuk konfigurasi awal atau nilai default sistem.
# ──────────────────────────────────────────────────────────────────────────────

# ── Konfigurasi Port & Akses ──────────────────────────────────────────────────
# Port Dashboard (Frontend)
FRONTEND_PORT_EXPOSE=3030

# Port API Backend (Opsional)
# Secara default hanya bisa diakses via Frontend (localhost:3030/api).
# Isi jika ingin mengakses API langsung dari host (misal: 8088).
BACKEND_PORT_EXPOSE=

# ── Kredensial Admin Awal (Gunakan untuk login pertama kali) ──────────────────
ADMIN_USER=admin
ADMIN_PASS=admin123

# ── API Keys (Opsional - Bisa diisi di sini atau via dashboard UI) ────────────
# OpenRouter (direkomendasikan — akses banyak model via satu API key)
OPENROUTER_API_KEY=

# LLM Providers lainnya
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=
GEMINI_API_KEY=

# ── Observability (Opsional) ──────────────────────────────────────────────────
# Jaeger tidak dijalankan secara default. Untuk menjalankannya, gunakan profile debug:
# ./run-apps.sh up --profile debug
# Atau set endpoint jika menggunakan Jaeger eksternal:
OTEL_EXPORTER_OTLP_ENDPOINT=
