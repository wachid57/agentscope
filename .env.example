# Copy this file to .env and fill in your API keys

# ── OpenRouter (recommended — akses 200+ model via satu API key) ──────────────
OPENROUTER_API_KEY=

# ── LLM Providers lainnya (opsional, jika tidak pakai OpenRouter) ─────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=
GEMINI_API_KEY=

# Optional: OpenTelemetry tracing via Jaeger
# Set this if you want to use the jaeger service from docker-compose
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
