# Copy this file to .env and fill in your values

# LLM provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# priva-invoice service
INVOICE_API_URL=http://localhost:8080
INVOICE_API_KEY=your-invoice-api-key-here

# priva-telegram service
TELEGRAM_API_URL=http://localhost:8080
TELEGRAM_JWT_TOKEN=<JWT dari POST /auth/login priva-telegram>
TELEGRAM_BOT_ID=<UUID bot dari GET /api/v1/telegram/bots>

# priva-gws (Google Workspace MCP) — untuk baca Google Sheets
GWS_API_URL=http://localhost:8083
GWS_API_KEY=<API key dari POST /api/v1.0/keys priva-gws>
GWS_USER_ID=<user ID yang sudah connect Google OAuth di priva-gws>
GWS_TENANT_ID=<tenant ID di priva-gws (opsional)>

# Scheduler — deteksi perubahan sheet otomatis
SPREADSHEET_ID=<ID Google Sheets yang dipantau, dari URL /d/<ID>/edit>
TELEGRAM_CHAT_ID=<Telegram chat ID tujuan notifikasi invoice>
SCHEDULER_INTERVAL=300          # interval poll dalam detik (default 5 menit)
SHEET_STATE_FILE=/app/state/sheet_state.json
